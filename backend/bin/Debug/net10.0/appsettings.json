{
  // ============================================================
  // appsettings.json — Backend configuration
  // Change the password below to match your PostgreSQL setup
  // ============================================================
  "ConnectionStrings": {
    // Format: Host=<server>;Port=<port>;Database=<dbname>;Username=<user>;Password=<pass>
    "DefaultConnection": "Host=localhost;Port=5432;Database=student_db;Username=postgres;Password=1234"
  },
  "Jwt": {
    // Secret key used to sign JWT tokens — change this to a long random string in production
    "Key": "YourSuperSecretKey_ChangeThisInProduction_Min32Chars!",
    "Issuer": "StudentAPI",
    "Audience": "StudentMSUsers",
    "ExpiresInMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
